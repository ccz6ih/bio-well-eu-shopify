    "faq": {
      "type": "faq",
      "blocks": {
        "question-1": {
          "type": "question",
          "settings": {
            "title": "Why is calibration required for Bio-Well measurements?",
            "text": "<p>Calibration ensures that the Bio-Well camera operates from a known and stable reference state.<br/><br/>Over time, environmental conditions, handling, and regular use can influence sensor sensitivity.<br/></p><p>The calibration unit resets the system, allowing measurements to remain accurate, consistent, and comparable over time.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-2": {
          "type": "question",
          "settings": {
            "title": "What does the Bio-Well Calibration Unit do?",
            "text": "<p>The calibration unit provides a controlled reference signal used by the Bio-Well software to adjust the camera before measurements.<br/>This process helps:</p><ul><li>maintain measurement accuracy</li><li>ensure repeatable results across sessions</li><li>prevent data drift during long-term use</li></ul>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-3": {
          "type": "question",
          "settings": {
            "title": "How is calibration performed?",
            "text": "<p>Calibration is fully guided by the Bio-Well software.<br/><br/>The calibration unit connects directly to the Bio-Well device, and the software leads the user step by step through the process.<br/></p><p>Calibration takes only a few moments and does not require technical expertise.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-4": {
          "type": "question",
          "settings": {
            "title": "When is a replacement calibration unit needed?",
            "text": "<p>A replacement or spare calibration unit may be required if:</p><ul><li>the original unit is lost or misplaced</li><li>the unit is physically damaged</li><li>persistent calibration errors occur</li><li>a backup unit is needed to avoid downtime in busy professional settings</li></ul><p>Every new Bio-Well camera already includes a calibration unit.<br/>This product is intended strictly as a <strong>replacement or spare part.</strong></p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-5": {
          "type": "question",
          "settings": {
            "title": "Is it important to use an original Bio-Well calibration unit?",
            "text": "<p>Yes. Using an original Bio-Well calibration unit ensures full compatibility with the system.<br/><br/>It guarantees that calibration meets Bio-Well’s technical specifications and quality standards, supporting reliable and professional measurement conditions.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "contact": {
          "type": "contact",
          "settings": {
            "heading": "Didn’t find your answer?",
            "text": "<p>Don't hestitate to contact us</p>",
            "show_phone": false,
            "avatar_height": 60,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
