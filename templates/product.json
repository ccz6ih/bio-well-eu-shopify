          "settings": {
            "subheading": "Progressive Integration",
            "heading": "<strong>Supporting continuity over time</strong>",
            "heading_tag": "h3",
            "text": "<p>By repeating exposure over time, Bio-Cor supports gradual integration and continuity between sessions, under practitioner supervision.<br/></p>",
