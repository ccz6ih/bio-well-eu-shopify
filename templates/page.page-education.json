            "image": "shopify://shop_images/koratkov.png",
            "image_mobile": "shopify://shop_images/koratkov.png",
            "subheading": "Measurement & Data Acquisition",
            "heading": "Precision before interpretation",
            "heading_tag": "h2",
            "text": "<p><br/>Proper measurement protocols, influencing factors, reproducibility standards, and quality control. A scan is only as good as the conditions under which it was taken — this module ensures your data is reliable before you begin to interpret it.<br/><br/>.</p>",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
            "button_external": false,
            "button_icon": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
