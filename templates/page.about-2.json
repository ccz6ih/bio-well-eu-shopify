{"sections":{"slideshow_gBQkJz":{"type":"slideshow","blocks":{"video_3FgYh9":{"type":"video","settings":{"video_url":"https:\/\/www.youtube.com\/watch?v=_9VUPq3SxOc","description":"","video_url_mobile":"","heading":"<em><strong>BIO-WELL Tech<\/strong><\/em>","heading_size":"title-lg tracking-heading","heading_tag":"h2","button_label":"","button_link":"","button_style":"primary","button_external":false,"button_icon":false}}},"block_order":["video_3FgYh9"],"name":"HERO INSTITUTIONNEL","settings":{"autoplay":true,"autoplay_speed":7,"show_navigation":false,"image_height":"400px","content_width":"small","image_height_mobile":"300px","accessibility_info":"Slideshow about our brand","color_text":"#ffffff","color_background":"","gradient_background":"","color_button_text":"#171717","color_button_background":"#ffffff","color_button_gradient":"","color_overlay":"#171717","overlay_opacity":20,"padding_top":60,"padding_bottom":0,"divider":false,"full_width":false,"rounded":false,"enable_parallax":false,"parallax_direction":"vertical"}},"rich_text_M4dQac":{"type":"rich-text","blocks":{"heading_4mFT8d":{"type":"heading","settings":{"heading":"Independent expertise in bioelectrography, research, and education.","heading_size":"title-lg tracking-heading","heading_tag":"h2","highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false}}},"block_order":["heading_4mFT8d"],"name":"HERO INSTITUTIONNEL","settings":{"text_alignment":"left","text_alignment_mobile":"left","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"rgba(0,0,0,0)","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":32,"padding_bottom":60,"divider":false,"narrow":true,"rounded":false}},"rich_text_dY9FrB":{"type":"rich-text","blocks":{"text_Ceyak6":{"type":"text","settings":{"text":"<p>BIO-WELL Tech is a team of independent therapists and researchers dedicated to health, prevention, and the professional use of bioelectrographic measurement through the GDV Bio-Well system.<br\/><\/p>","text_font":"heading","text_size":"subtext-xl","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}},"text_inEmtW":{"type":"text","settings":{"text":"<p>As one of the very first users of GDV\/EPC technology in France, we have been practicing energy imaging and bioelectrography for over twenty years. This long-standing involvement has allowed us to develop a structured, experience-based approach grounded in real-world practice rather than theoretical speculation.<\/p><p>BIO-WELL Tech is an official <strong>KTI-approved importer and distributor<\/strong> of the Bio-Well camera, ensuring full compliance with the manufacturer’s technical and professional standards.<br\/><br\/><\/p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["text_Ceyak6","text_inEmtW"],"name":"WHO WE ARE","settings":{"text_alignment":"left","text_alignment_mobile":"left","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"#ffffff","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":100,"divider":false,"narrow":true,"rounded":false}},"rich_text_FLyNbp":{"type":"rich-text","blocks":{"text_bQRNkc":{"type":"text","settings":{"text":"<p>Our commitment to bioelectrography is rooted in continuity and rigor.<\/p><p>Over the years, we have followed the evolution of GDV technology, integrating methodological improvements while maintaining a critical and responsible perspective. This long-term engagement allows us to approach Bio-Well not as a trend-driven tool, but as a system that requires precision, context, and proper understanding.<\/p><p>This perspective guides our work with practitioners, researchers, and institutions seeking reliable and reproducible approaches to energy imaging.<\/p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["text_bQRNkc"],"custom_css":[".block {word-break: normal;}"],"name":"LONG-TERM COMMITMENT","settings":{"text_alignment":"left","text_alignment_mobile":"left","heading":"A LONG-TERM COMMITMENT TO BIOELECTROGRAPHY","heading_size":"title-xl tracking-heading","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":100,"divider":false,"narrow":true,"rounded":false}},"image_with_text_p4CVkd":{"type":"image-with-text","blocks":{"heading_Ua9aVg":{"type":"heading","settings":{"heading":"<strong>SCIENTIFIC & EDUCATIONAL COLLABORATION<\/strong>","heading_size":"title-xl tracking-heading","heading_tag":"h2","highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false}},"text_f6nTKX":{"type":"text","settings":{"text":"<p>Our close collaboration with <strong>Konstantin Korotkov<\/strong>, the inventor of the Bio-Well system, enables us to coordinate and participate in scientific studies and research projects alongside him.<\/p><p>We regularly organize study trips and professional exchanges in different parts of the world, allowing direct contact with ongoing research and international expertise.<\/p><p>For more than fifteen years, we have trained doctors and therapists in the professional use of the Bio-Well camera, with a strong emphasis on correct protocols, interpretation frameworks, and ethical practice.<\/p><p>Each year, we take part in conferences at the <strong>SIS International Congress<\/strong> in Saint Petersburg, which brings together leading international specialists in the field. Whenever possible, we also organize delegations of French-speaking practitioners to attend this event.<br\/><br\/><\/p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["heading_Ua9aVg","text_f6nTKX"],"name":"SCIENTIFIC & EDUCATIONAL COLLABORATION","settings":{"image_height":"650px","image_width":"medium","layout":"text_first","text_alignment":"left","content_position":"align-self-center","image_height_mobile":"auto","text_alignment_mobile":"left","color_text":"","color_background":"#ffffff","gradient_background":"","color_background_2":"","gradient_background_2":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":72,"divider":false,"full_width":false,"rounded":false,"enable_parallax":true,"parallax_direction":"vertical"}},"rich_text_tJ9LE3":{"type":"rich-text","blocks":{"heading_hR9rgt":{"type":"heading","settings":{"heading":"<strong>TRAINING & KNOWLEDGE TRANSMISSION<\/strong>","heading_size":"title-xl tracking-heading","heading_tag":"h2","highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false}},"text_rRFyEz":{"type":"text","settings":{"text":"<p>Transmission of knowledge is a central pillar of our work.<\/p>","text_font":"heading","text_size":"subtext-xl","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}},"text_r8bRLU":{"type":"text","settings":{"text":"<p>We offer Bio-Well training courses, workshops, and seminars dedicated to the correct use and interpretation of bioelectrographic measurements. These programs are designed to help practitioners integrate the technology into structured professional frameworks while respecting methodological and ethical boundaries.<\/p><p>Our approach prioritizes understanding, reproducibility, and responsible use over simplified or reductive interpretations.<\/p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["heading_hR9rgt","text_rRFyEz","text_r8bRLU"],"name":"TRAINING & KNOWLEDGE TRANSMISSION","settings":{"text_alignment":"left","text_alignment_mobile":"left","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"rgba(0,0,0,0)","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":100,"divider":false,"narrow":true,"rounded":false}},"rich_text_NEjR3C":{"type":"rich-text","blocks":{"text_YVrEWV":{"type":"text","settings":{"text":"<p>Beyond formal training, we actively support exchange and dialogue among Bio-Well users.<\/p><p>We regularly organize professional exchange days in France, Spain, and other European countries (on request), bringing together practitioners from medical, paramedical, research, and exploratory backgrounds.<\/p><p>These meetings foster shared learning, interdisciplinary dialogue, and deeper collective understanding of the technology beyond isolated practice.<\/p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["text_YVrEWV"],"custom_css":[".block {word-break: normal;}"],"name":"INTERNATIONAL COMMUNITY OF PRACTICE","settings":{"text_alignment":"left","text_alignment_mobile":"left","heading":"AN INTERNATIONAL COMMUNITY OF PRACTICE","heading_size":"title-xl tracking-heading","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"#ffffff","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":100,"divider":false,"narrow":true,"rounded":false}},"highlight_text_3wGHAe":{"type":"highlight-text","blocks":{"text_FQn7Di":{"type":"text","settings":{"text":"<p>This multidisciplinary dynamic strengthens our collective perspective and ensures that Bio-Well technology is approached with both openness and critical thinking. It also allows us to confront different viewpoints, refine methodologies, and avoid oversimplified interpretations.<\/p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["text_FQn7Di"],"name":"MULTIDISCIPLINARY APPROACH","settings":{"text_alignment":"left","text_alignment_mobile":"left","heading":"<strong>A MULTIDISCIPLINARY AND OPEN APPROACH<\/strong>","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_tag":"h2","subheading":"","description":"<p>Our work is continuously enriched through interaction with a wide range of professionals, including doctors, engineers, university lecturers, geobiologists, therapists, and researchers.<\/p>","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":100,"divider":false,"narrow":true,"rounded":false}},"rich_text_MiimxU":{"type":"rich-text","blocks":{"heading_64d7em":{"type":"heading","settings":{"heading":"<strong>OUR VISION<\/strong>","heading_size":"title-lg tracking-heading","heading_tag":"h2","highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false}},"text_Tri7fx":{"type":"text","settings":{"text":"<p>We believe that meaningful progress in the exploration of energy-related phenomena requires rigor, curiosity, and ethical responsibility.<\/p><p>Our vision is to support a structured and transparent approach to bioelectrography—one that respects scientific inquiry, professional practice, and the complexity of interactions between physiology, environment, and energy.<\/p>","text_font":"body","text_size":"subtext-md","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["heading_64d7em","text_Tri7fx"],"name":"PROFESSIONAL SUMMARY \/ VISION","settings":{"text_alignment":"center","text_alignment_mobile":"center","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"#ffffff","color_background":"#00c7ff","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":100,"divider":false,"narrow":true,"rounded":false}},"rich_text_cKjg8K":{"type":"rich-text","blocks":{"text_rYnP7R":{"type":"text","settings":{"text":"<p><em><strong>For institutional, educational, or research inquiries, please contact us via the dedicated contact page.<br\/><\/strong><\/em><\/p>","text_font":"body","text_size":"subtext-xl","text_max_size":32,"text_line_height":1.6,"text_letter_spacing":0,"text_capitalize":false,"secondary_color":false,"highlighted_text":"none","highlighted_scribble":"circle"}}},"block_order":["text_rYnP7R"],"name":"CONTACT","settings":{"text_alignment":"center","text_alignment_mobile":"center","heading":"","heading_size":"title-md","heading_alignment":"text-left md:items-end md:flex-row","heading_width":"small","heading_tag":"h2","subheading":"","description":"","button_label":"","button_link":"","button_external":false,"button_icon":true,"highlighted_text":"none","highlighted_scribble":"circle","highlighted_reveal":false,"color_text":"","color_background":"#ffffff","gradient_background":"","color_highlight":"","gradient_highlight":"","color_button_text":"","color_button_background":"","color_button_gradient":"","padding_top":72,"padding_bottom":100,"divider":false,"narrow":true,"rounded":false}},"main-page":{"type":"main-page","settings":{"heading_size":"title-xl tracking-heading","heading_alignment":"text-left","heading_tag":"h1","text_size":"text-base","padding_top":72,"padding_bottom":120,"divider":false,"narrow":true,"rounded":false}}},"order":["slideshow_gBQkJz","rich_text_M4dQac","rich_text_dY9FrB","rich_text_FLyNbp","image_with_text_p4CVkd","rich_text_tJ9LE3","rich_text_NEjR3C","highlight_text_3wGHAe","rich_text_MiimxU","rich_text_cKjg8K","main-page"]}