<style>
 #shopify-section-{{ section.id }} {
 {%- render 'section-variables', section: section -%}
 }
</style>

<div class="section inline">
 <div class="relative contents">
 <reveal-banner class="reveal-banner relative inline">
 <span class="reveal-banner__tracker absolute top-0 h-full"></span>
 {%- if section.blocks.size > 0 -%}
 <span class="reveal-banner__tracker2nd absolute top-0 h-full"></span>
 {%- endif -%}
 <div class="reveal-banner__scroller{% if section.settings.enable_parallax %} sticky top-0 overflow-hidden{% endif %}">
 <div class="video-hero banner w-full h-screen{% if section.settings.enable_parallax %} relative{% else %} sticky top-0{% endif %}">
 {%- if section.settings.video_mobile or section.settings.video_url_mobile -%}
 {%- render 'video',
 sizes: '100vw',
 video: section.settings.video_mobile,
 video_url: section.settings.video_url_mobile,
 muted: true,
 autoplay: true,
 loop: true,
 controls: false,
 description: section.settings.description,
 cover_image: section.settings.cover_image_mobile,
 show_play_button: false,
 is_mobile: true,
 class: 'banner__media media media--height w-full h-full block relative overflow-hidden'
 -%}
 {%- endif -%}

 {%- render 'video',
 sizes: '100vw',
 video: section.settings.video,
 video_url: section.settings.video_url,
 muted: true,
 autoplay: true,
 loop: true,
 controls: false,
 description: section.settings.description,
 cover_image: section.settings.cover_image,
 show_play_button: false,
 class: 'banner__media media media--height w-full h-full block relative overflow-hidden'
 -%}

 {%- if section.blocks.size > 0 -%}
 <span class="banner__overlay absolute top-0 left-0 w-full h-full pointer-events-none"></span>
 <div class="banner__content overflow-hidden absolute z-1 top-0 left-0 w-full h-full">
 <div class="page-width w-full h-full flex {{ section.settings.content_position }} {{ section.settings.content_position_mobile }}">
 <div class="banner__box banner__box--{{ section.settings.content_width }} md:text-{{ section.settings.text_alignment }} text-{{ section.settings.text_alignment_mobile }}">
 {%- liquid
 assign with_gradient = false
 if section.settings.gradient_highlight != blank and section.settings.gradient_highlight != 'rgba(0,0,0,0)'
 assign with_gradient = true
 endif
 
 assign delay = 0
 -%}
 {%- comment -%} H1 SEO BLOCK - Displayed BEFORE other blocks {%- endcomment -%}
 {%- if section.settings.h1_heading != blank -%}
 <h1 class="banner__h1 heading leading-none {{ section.settings.h1_size }}" style="margin-bottom: {{ section.settings.h1_spacing }}px;">
 {{- section.settings.h1_heading -}}
 </h1>
 {%- endif -%}
 {%- for block in section.blocks -%}
 {%- case block.type -%}
 {%- when '@app' -%}
 {%- render block -%}
 
 {%- when 'spacing' -%}
 <empty-element class="block spacing-section{% if block.settings.height_mobile == 0 %} hidden lg:block{% endif %}{% if block.settings.height == 0 %} lg:hidden{% endif %}" style="--spacing-height-desktop: {{ block.settings.height }}px;--spacing-height-mobile: {{ block.settings.height_mobile }}px;" {{ block.shopify_attributes }}></empty-element>
 
 {%- when 'subheading' -%}
 {%- if block.settings.subheading != blank -%}
 <p class="banner__subheading heading uppercase leading-none tracking-widest {{ block.settings.subheading_size }}{% if block.settings.secondary_color %} banner__text--colored{% endif %}" {{ block.shopify_attributes }}>
 {{- block.settings.subheading -}}
 </p>
 {%- endif -%}
 
 {%- when 'heading' -%}
 {%- if block.settings.heading != blank -%}
 {%- assign delay = delay | plus: 1 -%}
 <{{ block.settings.heading_tag }} class="banner__title heading leading-none {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
 {%- render 'heading-content', content: block.settings.heading, style: block.settings.highlighted_text, scribble: block.settings.highlighted_scribble, reveal: block.settings.highlighted_reveal, gradient: with_gradient, delay: delay -%}
 </{{ block.settings.heading_tag }}>
 {%- endif -%}
 
 {%- when 'text' -%}
 {%- if block.settings.text != blank -%}
 <div class="rte {{ block.settings.text_font }} {{ block.settings.text_size }}{% if block.settings.text_font == 'subtitle' %} uppercase leading-tight tracking-widest{% else %} leading-normal{% endif %}{% if block.settings.secondary_color %} text-opacity{% endif %}"{% if block.settings.text_size == 'subtext-custom' %} style="--subtext-size: {{ block.settings.text_max_size }}px;--subtext-line-height: {{ block.settings.text_line_height }};--subtext-letter-spacing: {{ block.settings.text_letter_spacing | divided_by: 1000.00 }}em;{% if block.settings.text_capitalize %}--subtext-text-transform: uppercase;{% endif %}"{% endif %} {{ block.shopify_attributes }}>
 {%- render 'highlighted-text', content: block.settings.text, style: block.settings.highlighted_text, scribble: block.settings.highlighted_scribble, gradient: with_gradient -%}
 </div>
 {%- endif -%}
 
 {%- when 'icon' -%}
 {%- if block.settings.icon != 'none' or block.settings.icon_image != blank -%}
 {%- capture icon_content -%}
 {%- if block.settings.icon_image != blank -%}
 {%- liquid
 if block.settings.iwidth == 'fit'
 assign icon_width = block.settings.icon_image.width
 else
 assign icon_width = block.settings.icon_width
 endif
 assign image_alt = block.settings.icon_image.alt | default: block.settings.accessibility_info | escape
 assign max_width = block.settings.icon_image.width
 -%}
 <figure class="media media--transparent relative inline-block" {{ block.shopify_attributes }}>
 {%- capture sizes -%}{{ icon_width }}px{%- endcapture -%}
 {%- capture widths -%}{{ icon_width | times: 1.5 | at_most: max_width | round }}, {{ icon_width | times: 2 | at_most: max_width }}, {{ icon_width | times: 3 | at_most: max_width }}{%- endcapture -%}
 {{- block.settings.icon_image | image_url: width: max_width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, alt: image_alt, class: 'image-fit' -}}
 </figure>
 {%- elsif block.settings.icon != 'none' -%}
 {%- liquid
 if block.settings.iwidth == 'fit'
 render 'icon-guarantee', icon: block.settings.icon, size: 'lg', class: 'inline-block', shopify_attributes: block.shopify_attributes
 else
 render 'icon-guarantee', icon: block.settings.icon, size: 'custom', class: 'inline-block', width: block.settings.icon_width, shopify_attributes: block.shopify_attributes
 endif
 -%}
 {%- endif -%}
 {%- endcapture -%}

 <div class="leading-none">
 {%- if block.settings.link != blank -%}
 <a class="inline-block" href="{{ block.settings.link }}"{% if block.settings.external %} target="_blank" rel="noopener noreferrer"{% endif %} aria-label="{{ block.settings.accessibility_info | escape }}">
 {{- icon_content -}}
 </a>
 {%- else -%}
 {{- icon_content -}}
 {%- endif -%}
 </div>
 {%- endif -%}
 
 {%- when 'image' -%}
 {%- if block.settings.image != blank -%}
 <div class="leading-none" {{ block.shopify_attributes }}>
 <figure class="media media--transparent relative inline-block">
 {%- if block.settings.image_width == 'custom' -%}
 {%- capture style -%}--image-max-width: {{ block.settings.image_max_width }}px; --image-max-width-mobile: {{ block.settings.image_max_width_mobile }}px{%- endcapture -%}
 {%- capture sizes -%}(max-width: 767px) min({{ block.settings.image_max_width_mobile }}px, 100vw), min({{ block.settings.image_max_width }}px, 100vw){%- endcapture -%}
 {%- capture widths -%}{{ block.settings.image_max_width_mobile }},{{ block.settings.image_max_width_mobile | times: 2 }},{{ block.settings.image_max_width }},{{ block.settings.image_max_width | times: 2 }}{%- endcapture -%}
 {%- else -%}
 {%- assign sizes = 'min(100vw, var(--page-width))' -%}
 {%- assign widths = '50,75,100,150,200,300,400,500,750,1000,1250,1500,1750,2000,2250,2500,2750,3000,3200' -%}
 {%- endif -%}
 {{- block.settings.image | image_url: width: block.settings.image.width | image_tag: loading: 'lazy', sizes: sizes, widths: widths, style: style, is: 'lazy-image', class: 'image-fit' -}}
 </figure>
 </div>
 {%- endif -%}
 
 {%- when 'button' -%}
  {%- if block.settings.button_label != blank -%}
    {%- if block.settings.button_action == 'popup' -%}
      {%- if block.settings.button_style == 'link' -%}
        <button type="button" class="link inline-block{% if block.settings.button_icon %} icon-with-text{% endif %} button--fixed" is="hover-link" aria-controls="Popup-{{ block.id }}" aria-expanded="false" {{ block.shopify_attributes }}>
          <span class="link-text">{{ block.settings.button_label | escape }}</span>
          {%- liquid
            if block.settings.button_icon
              render 'icon', icon: 'arrow-right', size: 'sm', class: 'transform'
            endif
          -%}
        </button>
      {%- else -%}
        <button type="button" class="button button--{{ block.settings.button_style | default: 'primary' }} button--{{ block.settings.button_size | default: 'md' }} button--fixed" is="hover-button" aria-controls="Popup-{{ block.id }}" aria-expanded="false" {{ block.shopify_attributes }}>
          <span class="btn-fill" data-fill></span>
          <span class="btn-text">
            {%- liquid
              echo block.settings.button_label | escape
              if block.settings.button_icon
                render 'icon', icon: 'arrow-right', size: 'sm', class: 'transform'
              endif
            -%}
          </span>
        </button>
      {%- endif -%}

      {%- comment -%}
        Determine if it's a YouTube URL and extract the video ID
      {%- endcomment -%}
      {%- assign is_youtube = false -%}
      {%- assign youtube_id = '' -%}
      {%- assign iframe_url = block.settings.button_link -%}

      {%- if block.settings.button_link contains 'youtube.com' or block.settings.button_link contains 'youtu.be' or block.settings.button_link contains 'youtube-nocookie.com' -%}
        {%- assign is_youtube = true -%}
        {%- if block.settings.button_link contains 'youtu.be/' -%}
          {%- assign youtube_id = block.settings.button_link | split: 'youtu.be/' | last | split: '?' | first | split: '/' | first -%}
        {%- elsif block.settings.button_link contains 'youtube.com/embed/' -%}
          {%- assign youtube_id = block.settings.button_link | split: 'youtube.com/embed/' | last | split: '?' | first | split: '/' | first -%}
        {%- elsif block.settings.button_link contains 'youtube-nocookie.com/embed/' -%}
          {%- assign youtube_id = block.settings.button_link | split: 'youtube-nocookie.com/embed/' | last | split: '?' | first | split: '/' | first -%}
        {%- elsif block.settings.button_link contains 'youtube.com/shorts/' -%}
          {%- assign youtube_id = block.settings.button_link | split: 'youtube.com/shorts/' | last | split: '?' | first | split: '/' | first -%}
        {%- elsif block.settings.button_link contains 'v=' -%}
          {%- assign youtube_id = block.settings.button_link | split: 'v=' | last | split: '&' | first -%}
        {%- endif -%}
        {%- assign iframe_url = 'https://www.youtube.com/embed/' | append: youtube_id | append: '?playsinline=1&autoplay=1&enablejsapi=1' -%}
      {%- endif -%}

      {%- capture popup_content -%}
        <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen pointer-events-none" aria-controls="Popup-{{ block.id }}" aria-expanded="false"></overlay-element>
        <div class="drawer__inner z-10 absolute top-0 flex flex-col w-full h-full overflow-hidden">
          <gesture-element class="drawer__header flex justify-end opacity-0 invisible relative" tabindex="0">
            <button class="button button--secondary button--close drawer__close flex items-center justify-center" type="button" is="hover-button" aria-controls="Popup-{{ block.id }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
              <span class="btn-fill" data-fill></span>
              <span class="btn-text">
                {%- render 'icon', icon: 'close', size: 'sm' -%}
              </span>
            </button>
          </gesture-element>
          <div class="drawer__content opacity-0 invisible flex flex-col h-full grow shrink">
            <div class="drawer__scrollable relative flex flex-col gap-5 md:gap-7 grow shrink" style="padding-bottom: var(--sp-6);">
              <iframe-popup data-src="{{ iframe_url }}" class="w-full h-full block{% if is_youtube %} is-video{% endif %}">
                <iframe src="about:blank" class="w-full border-0" allow="autoplay; encrypted-media; fullscreen" allowfullscreen></iframe>
              </iframe-popup>
            </div>
          </div>
        </div>
      {%- endcapture -%}

      <x-modal id="Popup-{{ block.id }}" class="x-modal drawer z-30 fixed bottom-0 left-0 h-full w-full pointer-events-none"
        role="dialog"
        aria-modal="true"
        aria-label="{{ block.settings.button_label | escape }}"
        hidden
      >
        {{- popup_content -}}
      </x-modal>

      <style>
        iframe-popup.is-video iframe {
          aspect-ratio: 16 / 9;
          width: 100%;
          height: auto;
        }
        iframe-popup:not(.is-video) iframe {
          width: 100%;
          height: 600px;
          max-height: 70vh;
        }
      </style>

      <script>
        if (!customElements.get('iframe-popup')) {
          class IframePopup extends HTMLElement {
            connectedCallback() {
              this.modal = this.closest('x-modal, drawer-element');
              if (this.modal) {
                this.onToggle = this.handleToggle.bind(this);
                this.modal.addEventListener('toggle', this.onToggle);
              }
              this.iframe = this.querySelector('iframe');
              this.src = this.getAttribute('data-src');
            }

            disconnectedCallback() {
              if (this.modal) {
                this.modal.removeEventListener('toggle', this.onToggle);
              }
            }

            handleToggle() {
              if (this.modal.hasAttribute('open')) {
                if (this.iframe && this.iframe.src !== this.src) {
                  this.iframe.src = this.src;
                }
              } else {
                if (this.iframe && this.iframe.src !== 'about:blank') {
                  this.iframe.src = 'about:blank';
                }
              }
            }
          }
          customElements.define('iframe-popup', IframePopup);
        }
      </script>
    {%- else -%}
      {%- render 'button',
        label: block.settings.button_label,
        link: block.settings.button_link,
        size: block.settings.button_size,
        style: block.settings.button_style,
        external: block.settings.button_external,
        show_icon: block.settings.button_icon,
        classes: 'button--fixed',
        shopify_attributes: block.shopify_attributes
      -%}
    {%- endif -%}
  {%- endif -%}
 
 {%- when 'link' -%}
 {%- if block.settings.label != blank -%}
 <a class="link inline-block"{% if block.settings.link != blank %} href="{{ block.settings.link }}"{% if block.settings.external %} target="_blank" rel="noopener noreferrer"{% endif %}{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
 {{- block.settings.label -}}
 </a>
 {%- endif -%}
 
 {%- when 'liquid' -%}
 {%- if block.settings.liquid != blank -%}
 <div class="rte" {{ block.shopify_attributes }}>
 {{- block.settings.liquid -}}
 </div>
 {%- endif -%}
 {%- endcase -%}
 {%- endfor -%}
 </div>
 </div>
 </div>
 {%- endif -%}
 </div>
 </div>
 </reveal-banner>
 </div>
</div>

