    "timeline_Nym8Rq": {
      "type": "timeline",
      "blocks": {
        "content_LxNqLR": {
          "type": "content",
          "settings": {
            "subheading": "Measure the Environment",
            "heading": "Objective ambient energy measurement",
            "heading_tag": "h3",
            "text": "<p>Sputnik measures ambient energy by detecting variations in electrical polarization linked to the surrounding space.</p><p>Measurements can be performed indoors or outdoors, over short periods or extended durations.</p>",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
            "button_external": false,
            "button_icon": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
            "highlighted_reveal": false
          }
        },
        "content_UP7FLk": {
          "type": "content",
          "settings": {
            "subheading": "Capture Environmental Dynamics",
            "heading": "Observe how spaces evolve over time",
            "heading_tag": "h3",
            "text": "<p>The system records how locations change and how activities, groups, or natural factors influence the energetic state of a space.<br/>This allows dynamic observation rather than static snapshots.</p>",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
            "button_external": false,
            "button_icon": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
            "highlighted_reveal": false
          }
        },
        "content_TxKaQa": {
          "type": "content",
          "settings": {
            "subheading": "Analyze & Visualize",
            "heading": "Transform raw data into readable insights",
            "heading_tag": "h3",
            "text": "<p>Bio-Well software displays dynamic graphs and comparative visualizations.<br/></p><p>Practitioners can identify variations, trends, and energetic disruptions within an environment.</p>",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
            "button_external": false,
            "button_icon": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
            "highlighted_reveal": false
          }
        },
        "content_7RHKTm": {
          "type": "content",
          "settings": {
            "subheading": "Interpret",
            "heading": "Develop a structured reading methodology",
            "heading_tag": "h3",
            "text": "<p>Through Level 1 Bio-Well training, users learn how to interpret environmental data correctly.<br/></p><p>The focus is on contextual analysis and avoiding subjective or intuitive bias.</p>",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
            "button_external": false,
            "button_icon": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
            "highlighted_reveal": false
          }
        },
        "content_RgiFYT": {
          "type": "content",
          "settings": {
            "subheading": "Apply & Compare",
            "heading": "Support structured environmental evaluation",
            "heading_tag": "h3",
            "text": "<p>Measurements can be repeated to compare locations, activities, or time periods.<br/></p><p>This supports objective space evaluation, optimization, and long-term monitoring.</p>",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
            "button_external": false,
            "button_icon": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
