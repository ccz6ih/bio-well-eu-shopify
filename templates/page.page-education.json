        },
        "content_QXVYy6": {
          "type": "content",
          "settings": {
            "image": "shopify://shop_images/258eb842-0f2a-47f2-b9e9-116069c175cd-2026-04-16.png",
            "subheading": "Professional Application",
            "heading": "Where science meets service",
            "heading_tag": "h2",
            "text": "<p>Translating measurements into professional insights, structured reports, and session guidance — adapted to the realities of clinical, wellness, and research practice.</p>",
