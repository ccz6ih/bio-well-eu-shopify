        "content_Hkex9D": {
          "type": "content",
          "settings": {
            "image": "shopify://shop_images/bb4bc9bf-3bc2-4605-879a-56b75b6e13bc-2026-04-16.png",
            "subheading": "Certification & Professional Recognition",
            "heading": "Your expertise, validated",
            "heading_tag": "h2",
            "text": "<p>Final assessment, official certification, and entry into the global Bio-Well practitioner directory. Your certification confirms analytical competence and a commitment to responsible professional practice..</p>",
