      "name": "Practitioner Use Cases",
      "settings": {
        "text_alignment": "left",
        "text_alignment_mobile": "left",
        "heading": "Practitioner Use Cases",
        "heading_size": "title-md",
        "heading_alignment": "text-left md:items-end md:flex-row",
        "heading_width": "small",
        "heading_tag": "h2",
        "subheading": "",
        "description": "<p>Bio-Well is used by practitioners as an objective assessment tool to better understand functional regulation, stress load, and balance patterns in their clients.<br/>It provides measurable, visual data that supports observation, follow-up, and professional decision-making over time.<br/>Bio-Well integrates naturally into existing therapeutic, preventive, or research-oriented practices without modifying established protocols.<br/>Its standardized methodology allows practitioners to work with comparable data, track evolution, and reinforce the clarity of their interventions.<br/>The system supports both individual client work and structured professional practice.</p>",
        "button_label": "",
        "button_link": "",
        "button_external": false,
        "button_icon": true,
        "highlighted_text": "none",
