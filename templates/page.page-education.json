          }
        },
        "content_zKCKkD": {
          "type": "content",
          "settings": {
            "image": "shopify://shop_images/c2e86caf-6002-40ea-9705-4bee5b93ee60-2026-04-16.jpg",
            "subheading": "Data Interpretation & Analysis",
            "heading": "Where numbers become knowledge",
            "heading_tag": "h2",
            "text": "<p><br/>Interpreting diagrams, parameters, and indicators with nuance. Understanding variability, recognising meaningful patterns, and distinguishing genuine findings from measurement artefacts across sessions and client populations.<br/></p>",
            "button_label": "",
            "button_link": "",
            "button_style": "primary",
            "button_external": false,
            "button_icon": true,
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
