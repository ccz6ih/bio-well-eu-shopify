        "text_9yLdia": {
          "type": "text",
          "settings": {
            "text": "<p>Bio-Well is based on Gas Discharge Visualization (GDV),<br/> a technology that captures and analyzes electro-photonic emissions generated by biological systems.</p><p>Using advanced sensors and computer-based analysis, Bio-Well translates subtle electrical and photonic signals into clear, interpretable data.</p><p>This approach is not theoretical. GDV has been studied for decades and is used internationally in research, clinical practice, and performance optimization.</p>",
            "text_font": "body",
            "text_size": "subtext-sm",
