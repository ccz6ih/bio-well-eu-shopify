    "faq": {
      "type": "faq",
      "blocks": {
        "question-1": {
          "type": "question",
          "settings": {
            "title": "What is Bio-Well Elements designed to measure?",
            "text": "<p>Bio-Well Elements is designed to measure the energetic and photonic emissions of substances, whether biological or non-biological.<br/><br/>It allows the analysis of energetic signatures of solid and liquid materials using electro-photonic imaging generated by controlled electromagnetic impulses.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-2": {
          "type": "question",
          "settings": {
            "title": "Is Bio-Well Elements used on humans?",
            "text": "<p>No. Bio-Well Elements is not intended for direct use on humans.<br/><br/>It is a laboratory instrument designed for the study of substances and materials.<br/>In specific research protocols, indirect measurements related to animals may be performed, but the device is not a human assessment system.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-3": {
          "type": "question",
          "settings": {
            "title": "How does Bio-Well Elements work?",
            "text": "<p>Bio-Well Elements uses a large optical lens (9 × 12 cm), significantly larger than that of the Bio-Well 3.0 camera.<br/><br/>Objects, liquids, crystals, food samples, or remedies are placed in contact with the lens.<br/>An electromagnetic impulse generates an optical emission, which is captured and analyzed by dedicated software to reveal energetic patterns.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-4": {
          "type": "question",
          "settings": {
            "title": "What types of substances can be analyzed?",
            "text": "<p>Bio-Well Elements can be used to study a wide range of materials, including:</p><ul><li>Liquids (water, oils, tinctures, homeopathy, elixirs)</li><li>Crystals and minerals</li><li>Food and natural preparations</li><li>Health products, supplements, and vibrational remedies</li><li>Various materials (metals, fabrics, everyday objects)</li></ul><p>The impulse power can be adjusted according to the nature of the material being studied, allowing more refined measurements.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-5": {
          "type": "question",
          "settings": {
            "title": "What kind of results does Bio-Well Elements provide?",
            "text": "<p>Bio-Well Elements provides both visual and quantitative outputs.<br/><br/>Users can access dynamic visual representations of energetic emissions, as well as detailed parametric data suitable for comparative studies and statistical analysis.<br/></p><p>This dual-level approach makes the system particularly valuable for research, teaching, and product development.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_ttwEwa": {
          "type": "question",
          "settings": {
            "title": "Who is Bio-Well Elements designed for?",
            "text": "<p>Bio-Well Elements is designed for researchers, engineers, educators, and professionals interested in the energetic properties of substances.<br/><br/>It is commonly used in research laboratories, training environments, and exploratory studies related to energetic products or materials.<br/></p><p>Bio-Well Elements is not a medical device and does not replace chemical, biological, or clinical analysis.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "contact": {
          "type": "contact",
          "settings": {
            "heading": "Didn’t find your answer?",
            "text": "<p>Don't hestitate to contact us</p>",
            "show_phone": false,
            "avatar_height": 60,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },
