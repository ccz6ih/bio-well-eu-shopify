{%- liquid
  assign show_section = true

  if section.settings.only_homepage and request.page_type != 'index'
    assign show_section = false
  endif
-%}

{%- if show_section and section.settings.mode != 'disable' -%}
  <style>
    #shopify-section-{{ section.id }} {
      {%- render 'section-variables', section: section -%}
    }
  </style>

  {%- unless request.design_mode -%}
    <link rel="stylesheet" href="{{ 'popup-on-load.css' | asset_url }}" media="print" onload="this.media='all'">
    <noscript>{{ 'popup-on-load.css' | asset_url | stylesheet_tag }}</noscript>
  {%- else -%}
    {{ 'popup-on-load.css' | asset_url | stylesheet_tag }}
  {%- endunless -%}
  <script src="{{ 'popup-on-load.js' | asset_url }}" defer="defer"></script>

  <popup-modal id="PopupOnLoad-{{ section.id }}" class="popup-on-load x-modal drawer z-35 fixed bottom-0 left-0 h-full w-full pointer-events-none"
    data-delay="{{ section.settings.delay }}"
    data-expiry="{{ section.settings.expiry }}"
    data-test-mode="{% if section.settings.mode == 'testing' %}true{% else %}false{% endif %}"
    role="dialog"
    aria-labelledby="PopupOnLoad-{{ section.id }}-Heading"
    aria-modal="false"
    shopify-design-mode
    hidden
  >
    <overlay-element class="overlay fixed-modal invisible opacity-0 fixed bottom-0 left-0 w-full h-screen" aria-controls="PopupOnLoad-{{ section.id }}" aria-expanded="false"></overlay-element>

    <div class="drawer__inner z-10 flex flex-col w-full h-full relative overflow-hidden">
      <gesture-element class="drawer__header flex justify-end relative" tabindex="0">
        <button class="button button--secondary button--close drawer__close flex items-center justify-center" type="button" is="hover-button" aria-controls="PopupOnLoad-{{ section.id }}" aria-expanded="false" aria-label="{{ 'general.accessibility.close' | t | escape }}">
          <span class="btn-fill" data-fill></span>
          <span class="btn-text">
            {%- render 'icon', icon: 'close' -%}
          </span>
        </button>
      </gesture-element>

      <div class="drawer__content relative">
        <div class="popup__grid page-width w-full h-full flex md:items-center md:justify-start items-end justify-start {% if section.settings.image or section.settings.video or section.settings.video_url or section.settings.video_mobile or section.settings.video_url_mobile %} with-media{% endif %}">
          <div class="popup__body {{ section.settings.content_position_mobile }} {{ section.settings.content_position }}">
            <div class="popup__box popup__box--{{ section.settings.content_width }} md:text-{{ section.settings.text_alignment }} text-{{ section.settings.text_alignment_mobile }}">
              {%- liquid
                assign with_gradient = false
                if section.settings.gradient_highlight != blank and section.settings.gradient_highlight != 'rgba(0,0,0,0)'
                  assign with_gradient = true
                endif

                assign delay = 0
              -%}

              {%- for block in section.blocks -%}
                {%- case block.type -%}
                  {%- when 'spacing' -%}
                    <empty-element class="block spacing-section{% if block.settings.height_mobile == 0 %} hidden lg:block{% endif %}{% if block.settings.height == 0 %} lg:hidden{% endif %}" style="--spacing-height-desktop: {{ block.settings.height }}px;--spacing-height-mobile: {{ block.settings.height_mobile }}px;" {{ block.shopify_attributes }}></empty-element>

                  {%- when 'subheading' -%}
                    {%- if block.settings.subheading != blank -%}
                      <p class="popup__subheading banner__subheading heading uppercase leading-none tracking-widest subtitle-md banner__text--colored {{ block.settings.subheading_size }}{% if block.settings.secondary_color %} text-opacity{% endif %}" {{ block.shopify_attributes }}>
                        {{- block.settings.subheading -}}
                      </p>
                    {%- endif -%}

                  {%- when 'heading' -%}
                    {%- if block.settings.heading != blank -%}
                      {%- assign delay = delay | plus: 1 -%}
                      <{{ block.settings.heading_tag }} id="PopupOnLoad-{{ section.id }}-Heading{{ delay }}" class="popup__heading heading leading-none {{ block.settings.heading_size }}" {{ block.shopify_attributes }}>
                        {%- render 'heading-content', content: block.settings.heading, style: block.settings.highlighted_text, scribble: block.settings.highlighted_scribble, reveal: block.settings.highlighted_reveal, gradient: with_gradient, delay: delay -%}
                      </{{ block.settings.heading_tag }}>
                    {%- endif -%}

                  {%- when 'text' -%}
                    {%- if block.settings.text != blank -%}
                      <div class="rte {{ block.settings.text_font }} {{ block.settings.text_size }}{% if block.settings.text_font == 'subtitle' %} uppercase leading-tight tracking-widest{% else %} leading-normal{% endif %}{% if block.settings.secondary_color %} text-opacity{% endif %}"{{ ' ' }}
                        {%- if block.settings.text_size == 'subtext-custom' -%}
                          style="--subtext-size: {{ block.settings.text_max_size }}px;--subtext-line-height: {{ block.settings.text_line_height }};--subtext-letter-spacing: {{ block.settings.text_letter_spacing | divided_by: 1000.00 }}em;{% if block.settings.text_capitalize %}--subtext-text-transform: uppercase;{% endif %}"
                        {%- endif -%}
                        {{ block.shopify_attributes }}
                      >
                        {%- render 'highlighted-text', content: block.settings.text, style: block.settings.highlighted_text, scribble: block.settings.highlighted_scribble, gradient: with_gradient -%}
                      </div>
                    {%- endif -%}

                  {%- when 'button' -%}
                    {%- if block.settings.button_label != blank -%}
                      {%- render 'button',
                        label: block.settings.button_label,
                        link: block.settings.button_link,
                        size: block.settings.button_size,
                        style: block.settings.button_style,
                        external: block.settings.button_external,
                        show_icon: block.settings.button_icon,
                        classes: 'popup__button',
                        shopify_attributes: block.shopify_attributes
                      -%}
                    {%- endif -%}

                  {%- when 'link' -%}
                    {%- if block.settings.label != blank -%}
                      <a class="link inline-block"{% if block.settings.link != blank %} href="{{ block.settings.link }}"{% if block.settings.external %} target="_blank" rel="noopener noreferrer"{% endif %}{% else %} role="link" aria-disabled="true"{% endif %} {{ block.shopify_attributes }}>
                        {{- block.settings.label -}}
                      </a>
                    {%- endif -%}

                  {%- when 'liquid' -%}
                    {%- if block.settings.liquid != blank -%}
                      <div class="rte" {{ block.shopify_attributes }}>
                        {{- block.settings.liquid -}}
                      </div>
                    {%- endif -%}
                {%- endcase -%}
              {%- endfor -%}
            </div>
          </div>

          {%- if section.settings.image or section.settings.video or section.settings.video_url or section.settings.video_mobile or section.settings.video_url_mobile -%}
            <div class="popup__media">
              {%- if section.settings.video_mobile or section.settings.video_url_mobile -%}
                {%- render 'video',
                  sizes: '100vw',
                  video: section.settings.video_mobile,
                  video_url: section.settings.video_url_mobile,
                  muted: section.settings.video_autoplay,
                  autoplay: section.settings.video_autoplay,
                  loop: section.settings.video_loop,
                  controls: section.settings.video_controls,
                  description: section.settings.description,
                  cover_image: section.settings.cover_image_mobile,
                  show_play_button: section.settings.show_play_button,
                  is_mobile: true,
                  class: 'banner__media media media--height w-full h-full block'
                -%}
              {%- endif -%}

              {%- render 'video',
                sizes: '100vw',
                video: section.settings.video,
                video_url: section.settings.video_url,
                muted: section.settings.video_autoplay,
                autoplay: section.settings.video_autoplay,
                loop: section.settings.video_loop,
                controls: section.settings.video_controls,
                description: section.settings.description,
                cover_image: section.settings.cover_image,
                show_play_button: section.settings.show_play_button,
                class: 'banner__media media media--height w-full h-full block'
              -%}

              {%- if section.settings.image and section.settings.video == blank and section.settings.video_url == blank -%}
                {%- if section.settings.image -%}
                  <div class="popup__image">
                    {{- section.settings.image | image_url: width: section.settings.image.width | image_tag: loading: 'eager', fetchpriority: 'high', sizes: '(max-width: 767px) 100vw, 50vw', widths: '375,640,750,1080,1280,1500,1920,2560,3200', is: 'lazy-image', class: 'w-full h-full object-cover' -}}
                  </div>
                {%- endif -%}
              {%- endif -%}

              {%- if section.settings.overlay_opacity > 0 -%}
                <span class="banner__overlay absolute top-0 left-0 w-full h-full pointer-events-none" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.00 }};"></span>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </popup-modal>
{%- endif -%}

{% schema %}
{
  "name": "Popup on load",
  "class": "popup-on-load-section",
  "tag": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "Displays a popup with a video background and flexible content blocks that opens when the page loads."
    },
    {
      "type": "select",
      "id": "mode",
      "options": [
        { "value": "enabled", "label": "Enabled" },
        { "value": "testing", "label": "Test mode (always show)" },
        { "value": "disable", "label": "Désactiver" }
      ],
      "default": "enabled",
      "label": "Mode",
      "info": "Test mode always shows the popup, ignoring the cookie."
    },
    {
      "type": "checkbox",
      "id": "only_homepage",
      "label": "Show only on homepage",
      "default": true
    },
    {
      "type": "range",
      "id": "delay",
      "max": 30,
      "min": 0,
      "step": 1,
      "unit": "s",
      "label": "Delay before showing",
      "default": 0
    },
    {
      "type": "range",
      "id": "expiry",
      "max": 30,
      "min": 1,
      "step": 1,
      "unit": "d",
      "label": "Don't show again for",
      "default": 7
    },
    {
      "type": "header",
      "content": "Video / Image"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (desktop)"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "External video URL (YouTube/Vimeo)",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "video",
      "id": "video_mobile",
      "label": "Video (mobile)"
    },
    {
      "type": "video_url",
      "id": "video_url_mobile",
      "label": "External video URL mobile (YouTube/Vimeo)",
      "accept": ["youtube", "vimeo"]
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover image / poster (desktop)"
    },
    {
      "type": "image_picker",
      "id": "cover_image_mobile",
      "label": "Cover image / poster (mobile)"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Fallback image",
      "info": "Used when no video is provided."
    },
    {
      "type": "text",
      "id": "description",
      "label": "Video description (accessibility)"
    },
    {
      "type": "header",
      "content": "Video options"
    },
    {
      "type": "checkbox",
      "id": "video_autoplay",
      "label": "Autoplay",
      "default": true,
      "info": "Autoplay requires the video to be muted (browser policy). To play with sound, disable autoplay and the user will click play on the video."
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_controls",
      "label": "Show controls",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_play_button",
      "label": "Show play button overlay (poster)",
      "default": true
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "content_width",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium",
      "label": "Content width"
    },
    {
      "type": "select",
      "id": "content_position",
      "options": [
        { "value": "md:items-start md:justify-start", "label": "Top left" },
        { "value": "md:items-start md:justify-center", "label": "Top center" },
        { "value": "md:items-start md:justify-end", "label": "Top right" },
        { "value": "md:items-center md:justify-start", "label": "Center left" },
        { "value": "md:items-center md:justify-center", "label": "Center" },
        { "value": "md:items-center md:justify-end", "label": "Center right" },
        { "value": "md:items-end md:justify-start", "label": "Bottom left" },
        { "value": "md:items-end md:justify-center", "label": "Bottom center" },
        { "value": "md:items-end md:justify-end", "label": "Bottom right" }
      ],
      "default": "md:items-center md:justify-center",
      "label": "Content position (desktop)"
    },
    {
      "type": "select",
      "id": "content_position_mobile",
      "options": [
        { "value": "items-start justify-start", "label": "Top left" },
        { "value": "items-start justify-center", "label": "Top center" },
        { "value": "items-start justify-end", "label": "Top right" },
        { "value": "items-center justify-start", "label": "Center left" },
        { "value": "items-center justify-center", "label": "Center" },
        { "value": "items-center justify-end", "label": "Center right" },
        { "value": "items-end justify-start", "label": "Bottom left" },
        { "value": "items-end justify-center", "label": "Bottom center" },
        { "value": "items-end justify-end", "label": "Bottom right" }
      ],
      "default": "items-end justify-center",
      "label": "Content position (mobile)"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment",
      "default": "center",
      "label": "Text alignment (desktop)"
    },
    {
      "type": "text_alignment",
      "id": "text_alignment_mobile",
      "default": "center",
      "label": "Text alignment (mobile)"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Media overlay opacity",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "New"
        },
        {
          "type": "select",
          "id": "subheading_size",
          "options": [
            { "value": "subtitle-sm", "label": "Small" },
            { "value": "subtitle-md", "label": "Medium" },
            { "value": "subtitle-lg", "label": "Large" }
          ],
          "default": "subtitle-md",
          "label": "Size"
        },
        {
          "type": "checkbox",
          "id": "secondary_color",
          "label": "Use secondary color",
          "default": true
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Discover our new collection"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "title-sm", "label": "Small" },
            { "value": "title-md", "label": "Medium" },
            { "value": "title-lg tracking-heading", "label": "Large" },
            { "value": "title-xl tracking-heading", "label": "Extra large" }
          ],
          "default": "title-lg tracking-heading",
          "label": "Size"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "options": [
            { "value": "h1", "label": "H1" },
            { "value": "h2", "label": "H2" },
            { "value": "h3", "label": "H3" },
            { "value": "div", "label": "Div" }
          ],
          "default": "h2",
          "label": "Tag"
        },
        {
          "type": "header",
          "content": "Highlight"
        },
        {
          "type": "select",
          "id": "highlighted_text",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "text", "label": "Text" },
            { "value": "full_text", "label": "Full text" },
            { "value": "half_text", "label": "Half text" },
            { "value": "underline", "label": "Underline" },
            { "value": "marker", "label": "Marker" },
            { "value": "stencil", "label": "Stencil" },
            { "value": "scribble", "label": "Scribble" }
          ],
          "default": "none",
          "label": "Style"
        },
        {
          "type": "checkbox",
          "id": "highlighted_reveal",
          "label": "Reveal animation",
          "default": false
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Watch the video to learn more and click the button to shop the look.</p>"
        },
        {
          "type": "select",
          "id": "text_font",
          "options": [
            { "value": "body", "label": "Body" },
            { "value": "heading", "label": "Heading" },
            { "value": "subtitle", "label": "Subtitle" }
          ],
          "default": "body",
          "label": "Font"
        },
        {
          "type": "select",
          "id": "text_size",
          "options": [
            { "value": "subtext-sm", "label": "Small" },
            { "value": "subtext-md", "label": "Medium" },
            { "value": "subtext-lg", "label": "Large" },
            { "value": "subtext-xl", "label": "Extra large" }
          ],
          "default": "subtext-md",
          "label": "Size"
        },
        {
          "type": "checkbox",
          "id": "secondary_color",
          "label": "Use secondary color",
          "default": false
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "label": "Label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Link"
        },
        {
          "type": "select",
          "id": "button_style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" },
            { "value": "link", "label": "Link" }
          ],
          "default": "primary",
          "label": "Style"
        },
        {
          "type": "select",
          "id": "button_size",
          "options": [
            { "value": "sm", "label": "Small" },
            { "value": "md", "label": "Medium" },
            { "value": "lg", "label": "Large" }
          ],
          "default": "md",
          "label": "Size"
        },
        {
          "type": "checkbox",
          "id": "button_external",
          "label": "Open in new tab",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "button_icon",
          "label": "Show arrow icon",
          "default": true
        }
      ]
    },
    {
      "type": "link",
      "name": "Text link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Text",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "checkbox",
          "id": "external",
          "label": "Open in new tab",
          "default": false
        }
      ]
    },
    {
      "type": "spacing",
      "name": "Spacing",
      "settings": [
        {
          "type": "range",
          "id": "height",
          "label": "Height (desktop)",
          "default": 16,
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "height_mobile",
          "label": "Height (mobile)",
          "default": 12,
          "min": 0,
          "max": 100,
          "step": 4,
          "unit": "px"
        }
      ]
    },
    {
      "type": "liquid",
      "name": "Custom Liquid",
      "settings": [
        {
          "type": "liquid",
          "id": "liquid",
          "label": "Liquid code"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Popup on load",
      "blocks": [
        { "type": "subheading" },
        { "type": "heading" },
        { "type": "text" },
        { "type": "button" }
      ]
    }
  ],
  "enabled_on": {
    "groups": ["custom.overlay"]
  }
}
{% endschema %}
