        "text_fapU8x": {
          "type": "text",
          "settings": {
            "text": "<p>Professor of Computer Science and Biophysics at ITMO University (Saint Petersburg) and Senior Researcher at the Saint Petersburg Research Institute of Physical Culture and Sport. President of the International Union of Medical and Applied Bioelectrography (IUMAB) and Director of Bio-Well Companies. He holds 17 patents in biophysics and has authored several books, including <em>Light After Life</em> (1998), <em>Human Energy Field Study with GDV Bioelectrography</em> (2002), and <em>The Energy of Consciousness</em> (2012). He developed the Gas Discharge Visualization (GDV) technique — based on the Kirlian effect — which forms the foundation of the Bio-Well camera for real-time visualization of the human energy field.<br/><br/></p>",
            "text_font": "body",
            "text_size": "subtext-md",
            "text_max_size": 32,
