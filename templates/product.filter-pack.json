    "faq": {
      "type": "faq",
      "blocks": {
        "question-1": {
          "type": "question",
          "settings": {
            "title": "Why are Bio-Well filters required for every scan?",
            "text": "<p>Bio-Well filters create a protective barrier between the skin and the sensor.<br/><br/>They prevent moisture, skin oils, and residues from interfering with the capture of electro-photonic emissions, ensuring reliable and usable data for every measurement.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-2": {
          "type": "question",
          "settings": {
            "title": "How do filters improve measurement reliability?",
            "text": "<p>A clean and dry contact surface is essential for accurate electro-photonic imaging.<br/><br/>By reducing moisture-related interference, filters help ensure that each scan reflects the subject’s actual energetic state.<br/>This consistency is critical for reproducible measurements and before/after comparisons over time.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-3": {
          "type": "question",
          "settings": {
            "title": "Do filters protect the Bio-Well camera?",
            "text": "<p>Yes. Filters protect the sensor from direct contact with sweat, skin oils and contaminants.<br/><br/>This helps preserve calibration, reduces wear, and extends the lifespan of the Bio-Well camera in regular professional use.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-4": {
          "type": "question",
          "settings": {
            "title": "Are filters required for hygiene purposes?",
            "text": "<p>Yes. Using a new filter for each person is essential to meet professional hygiene standards.<br/><br/>This is particularly important in clinical, research, educational or event-based contexts, and helps maintain trust and a clean user experience.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-5": {
          "type": "question",
          "settings": {
            "title": "How many filters are typically used in professional practice?",
            "text": "<p>On average, a practitioner performing 5 to 10 scans per day uses between 150 and 300 filters per month.<br/><br/>A 100-filter pack usually lasts 2 to 4 weeks, depending on activity level.<br/>It is recommended to keep multiple packs available to avoid interruptions.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "contact": {
          "type": "contact",
          "settings": {
            "heading": "Didn’t find your answer?",
            "text": "<p>Don't hestitate to contact us</p>",
            "show_phone": false,
            "avatar_height": 60,
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },
